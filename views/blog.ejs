<!DOCTYPE html>
<html lang="zh-CN">
<head>
  <%- include('partials/head') %>
</head>
<body>
  <canvas id="bg"></canvas>
  <%- include('partials/nav', { currentPage: 'blog' }) %>

  <main class="main-content">

<div class="page-header" data-animate="fade-up">
  <h1 class="page-title">
    <span class="section-seal">文章</span>
  </h1>
  <p class="page-desc">以笔墨记录考研路上的寸进之功</p>
</div>

<% if (tags && tags.length > 0) { %>
<div class="tag-cloud" data-animate="fade-up" style="--delay:0.1s">
  <a href="/blog" class="<%= activeTag === '' ? 'active' : '' %>">全部</a>
  <% tags.forEach(t => { %>
    <a href="/blog?tag=<%= encodeURIComponent(t.name) %>" class="<%= activeTag === t.name ? 'active' : '' %>"><%= t.name %></a>
  <% }) %>
</div>
<% } %>

<div class="posts-grid-full" data-animate="fade-up" style="--delay:0.15s">
  <% if (posts.length === 0) { %>
    <div class="empty-state">
      <div class="empty-icon">&#x270D;</div>
      <p>尚无文章，去笔耕处写一篇</p>
    </div>
  <% } %>

  <% posts.forEach(post => { %>
  <a href="/blog/<%= post.slug %>" class="post-card post-card-large">
    <div class="post-card-tags">
      <% if (post.tags) { post.tags.split(',').forEach(tag => { %>
        <span class="post-tag"><%= tag.trim() %></span>
      <% })} %>
    </div>
    <h3 class="post-card-title"><%= post.title %></h3>
    <p class="post-card-excerpt"><%= post.excerpt || post.content.replace(/[#*`>\-\|\n\[\]\(\)]/g, '').substring(0, 120) %></p>
    <div class="post-card-meta">
      <span class="post-card-date"><%= new Date(post.created_at).toLocaleDateString('zh-CN') %></span>
      <span class="post-card-arrow">&#x2192;</span>
    </div>
  </a>
  <% }) %>
</div>

<% if (totalPages > 1) { %>
<div class="pagination" data-animate="fade-up" style="--delay:0.3s">
  <% if (currentPage > 1) { %>
    <a href="/blog?page=<%= currentPage - 1 %>" class="page-btn">&#x2190; 前页</a>
  <% } %>
  <% for (let i = 1; i <= totalPages; i++) { %>
    <a href="/blog?page=<%= i %>" class="page-btn <%= i === currentPage ? 'page-btn-active' : '' %>"><%= i %></a>
  <% } %>
  <% if (currentPage < totalPages) { %>
    <a href="/blog?page=<%= currentPage + 1 %>" class="page-btn">后页 &#x2192;</a>
  <% } %>
</div>
<% } %>

  <%- include('partials/footer') %>
